# --- Firebase Web SDK (public) ---
NUXT_PUBLIC_FIREBASE_API_KEY=
NUXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NUXT_PUBLIC_FIREBASE_PROJECT_ID=your-project
NUXT_PUBLIC_FIREBASE_APP_ID=
NUXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=

# --- Server secrets ---
# Default: place serviceAccount.json at the repo root (gitignored) — it is
# auto-detected. Or set one of these overrides:
# FIREBASE_SERVICE_ACCOUNT_PATH=/abs/path/serviceAccount.json
# FIREBASE_SERVICE_ACCOUNT=   # base64 of the JSON
MONGO_URI=mongodb://localhost:27017/cambio-uruguay
