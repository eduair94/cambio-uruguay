# --- Firebase Web SDK (public) ---
NUXT_PUBLIC_FIREBASE_API_KEY=
NUXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NUXT_PUBLIC_FIREBASE_PROJECT_ID=your-project
NUXT_PUBLIC_FIREBASE_APP_ID=
NUXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NUXT_PUBLIC_MAPTILER_API_KEY=

# --- Server secrets ---
# Default: place serviceAccount.json at the repo root (gitignored) — it is
# auto-detected. Or set one of these overrides:
# FIREBASE_SERVICE_ACCOUNT_PATH=/abs/path/serviceAccount.json
# FIREBASE_SERVICE_ACCOUNT=   # base64 of the JSON
MONGO_URI=mongodb://localhost:27017/cambio-uruguay

# --- Import-cart eBay item resolver (FlareSolverr-backed proxy) ---
# eBay 403s direct server fetches; this proxy returns item JSON. Endpoint takes
# ?url=<encoded ebay item url>. Unset -> eBay links fall back to manual entry.
EBAY_ITEM_API_URL=https://your-proxy.example.com/ebay/item

# --- Telegram account linking ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_BOT_SECRET=

# --- Reddit API (daily bank-sentiment harvest for /mejores-bancos-uruguay) ---
# App-only "installed_client" credentials: create a "script"/"installed" app at
# https://www.reddit.com/prefs/apps — no user account or password is needed.
# Unset -> the `reddit:sentiment` task no-ops and the page serves the last snapshot.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
# Reddit blocks generic User-Agents; keep it descriptive.
REDDIT_USER_AGENT=nodejs:cambio-uruguay:v1.0 (+https://cambio-uruguay.com)
# Optional shared secret for POST /api/reddit-sentiment/refresh (manual backfill).
NUXT_REDDIT_REFRESH_TOKEN=

# --- Discord OAuth2 login (server-side -> Firebase custom token) ---
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=https://cambio-uruguay.com/api/auth/discord/callback
# Optional community invite shown on /conectar (empty -> login-only card)
DISCORD_INVITE_URL=
