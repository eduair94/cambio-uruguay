# Prex USD scrape (cambiomoneda page). PREX_USER_ID = your numeric account id (URL segment).
# PREX_SESSION_ID = seed PHPSESSID cookie; the scraper auto-refreshes it (cached to prex_session.txt).
PREX_USER_ID=1234
PREX_SESSION_ID=your_phpsessid_cookie
# Auto cookie refresh: web login mints a fresh PHPSESSID when the cookie expires.
# PREX_LOGIN_USER = documento (CI, no dots/dashes); PREX_LOGIN_PASSWORD = web password.
# PREX_OTP_URL = endpoint returning the emailed 6-digit code as JSON {code, receivedAt}.
PREX_LOGIN_USER=12345678
PREX_LOGIN_PASSWORD=your_web_password
PREX_OTP_URL=https://your-mailbox-endpoint/code?to=you@example.com&want=code

# OCA USD scrape (authenticated Mi Cuenta quotation table).
# Use the CI without dots/dashes and the Mi Cuenta/App password.
# A successful login is cached in gitignored oca_session.json and reused until it expires.
OCA_LOGIN_USER=12345678
OCA_LOGIN_PASSWORD=your_web_password
# OCA_SESSION_CACHE_PATH=oca_session.json

# Santander USD scrape (Supernet).
# Recommended: use the CI without dots/dashes plus the web password. The scraper
# logs in only when its cached session expires; the cache is gitignored.
SANTANDER_LOGIN_USER=12345678
SANTANDER_LOGIN_PASSWORD=your_web_password
# Optional portal identifier prefix (Uruguay CI default)
SANTANDER_PORTAL_DOCUMENT_PREFIX=858-01
# Optional overrides for non-standard logins:
# SANTANDER_USERNAME=858-1-12345678
# SANTANDER_LOGIN_KIND=person
# SANTANDER_COUNTRY_DOCUMENT_PREFIX=858-1
# Manual-session fallback: copy BOTH values from the same authenticated request.
# Do not combine stale manual tokens with credential mode.
# SANTANDER_AUTH_TOKEN=
# SANTANDER_SESSION_ID=
# SANTANDER_APP_VERSION=10.9.3
# SANTANDER_SESSION_CACHE_PATH=santander_session.json
# SANTANDER_DISABLE_SESSION_CACHE=false

# Other scraper/API credentials. Never commit real values.
POSITIONSTACK_API_KEY=your_positionstack_access_key
CAMBIO_SIR_INSTANCE=your_wix_instance_token

# Scotiabank USD/EUR/UI scrape (authenticated Scotia en Línea widget).
# Use the regular Scotia en Línea user (CI) and password. A successful
# session is cached in gitignored scotiabank_session.json until it expires.
SCOTIABANK_LOGIN_USER=12345678
SCOTIABANK_LOGIN_PASSWORD=your_web_password
# SCOTIABANK_SESSION_CACHE_PATH=scotiabank_session.json

# AI Insights Configuration (OpenAI-compatible API)
# Latest wormgpt model as of 2026-06: wormv5.1 (also: wormv5.0, wormv4.5, worm-coder, wormv-auto)
AI_BASE_URL=https://wormgpt.checkleaked.com/v1
AI_API_KEY=your_api_key_here
AI_MODEL=wormv5.1
