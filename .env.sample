# Prex USD scrape: log into prexcard.com (web), copy the PHPSESSID cookie + your numeric user id.
# Cookie expires periodically — refresh PREX_SESSION_ID when USD stops updating.
PREX_USER_ID=1234
PREX_SESSION_ID=your_phpsessid_cookie

# AI Insights Configuration (OpenAI-compatible API)
# Latest wormgpt model as of 2026-06: wormv5.1 (also: wormv5.0, wormv4.5, worm-coder, wormv-auto)
AI_BASE_URL=https://wormgpt.checkleaked.com/v1
AI_API_KEY=your_api_key_here
AI_MODEL=wormv5.1