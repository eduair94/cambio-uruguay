# cambio-uruguay-bots — all optional; a channel is skipped if its vars are absent.

# Data source (defaults to the public API)
API_BASE_URL=https://api.cambio-uruguay.com

# Telegram (BotFather token + a channel id like @cambio_uruguay or -100123456789)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=

# Discord (bot for slash commands + a channel webhook for daily posts)
DISCORD_BOT_TOKEN=
DISCORD_APP_ID=
DISCORD_WEBHOOK_URL=

# Twitter/X (OAuth 1.0a, read+write, needed for media upload)
TWITTER_APP_KEY=
TWITTER_APP_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# Mongo (subscribers + alert state); subscriptions disabled if absent
MONGO_URI=

# Report / alert tuning
DEFAULT_BROADCAST_LANG=es
REPORT_CURRENCIES=USD,EUR,ARS,BRL
ALERT_CURRENCIES=USD,EUR,ARS,BRL
ALERT_THRESHOLD_PCT=1
ALERT_COOLDOWN_MIN=120

# OG image base (where /api/og-rate lives)
SITE_BASE_URL=https://cambio-uruguay.com

# Safety
DRY_RUN=
FORCE=
